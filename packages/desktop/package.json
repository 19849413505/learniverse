{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Learniverse Promax Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.learniverse.promax",
    "productName": "Learniverse Setup",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "../frontend/out/**/*",
      "../backend/dist/**/*",
      "../backend/node_modules/**/*",
      "../backend/package.json",
      "../backend/prisma/**/*",
      "../backend/learniverse.db"
    ]
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8"
  }
}
